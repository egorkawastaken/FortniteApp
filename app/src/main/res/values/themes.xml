<resources>

    <style name="Theme.FortniteApp" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:toolbarStyle">@style/FortniteCustomToolbar</item>
        <item name="android:buttonStyle">@style/FortniteCustomButton</item>
        <item name="colorPrimary">@color/blue</item>
        <item name="android:fitsSystemWindows">true</item>
        <item name="colorPrimaryDark">@color/gray</item>
        <item name="progressBarStyle">@style/FortniteCustomProgressBar</item>
        <item name="colorControlHighlight">@color/blue</item>
        <item name="android:colorControlHighlight">@color/blue</item>
        <item name="buttonStyle">@style/FortniteCustomButton</item>
        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:fontFamily">@font/montserrat_bold</item>
        <item name="android:textSize">24sp</item>
        <item name="colorAccent">@color/blue</item>
    </style>

    <!-- Стиль для Toolbar -->
    <style name="FortniteCustomToolbar" parent="Widget.AppCompat.Toolbar">
        <item name="android:background">@color/blue</item>
        <item name="titleTextAppearance">@style/FortniteCustomToolbarTitle</item>
    </style>

    <!-- Стиль текста в Toolbar -->
    <style name="FortniteCustomToolbarTitle" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:fontFamily">@font/montserrat_bold</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:titleTextColor">@color/white</item>
    </style>

    <!-- Стиль для кнопок -->
    <style name="FortniteCustomButton" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/yellow</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:fontFamily">@font/montserrat_bold</item>
        <item name="android:textSize">24sp</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <!-- Стиль для прогресс бара -->
    <style name="FortniteCustomProgressBar" parent="Widget.MaterialComponents.CircularProgressIndicator">
        <item name="android:indeterminate">true</item>
        <item name="android:layout_width">@dimen/default_drawable</item>
        <item name="android:layout_height">@dimen/default_drawable</item>
    </style>

    <!-- Cтиль для TextInputEditText -->
    <style name="FortniteTextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/white</item>
        <item name="boxStrokeColor">@color/blue</item>
        <item name="boxStrokeWidth">2dp</item>
        <item name="cursorColor">@color/blue</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <style name="FortniteEditText" parent="Widget.MaterialComponents.TextInputEditText.FilledBox">
        <item name="android:textColor">@color/gray</item>
        <item name="android:textSize">16sp</item>
        <item name="cursorColor">@color/blue</item>
        <item name="hintTextColor">@color/light_gray</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

</resources>